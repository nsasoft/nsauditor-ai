SEND_TO_OPENAI=true
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
SCAN_OUT_PATH=out/scan_response.json
OPENAI_PROMPT_MODE=optimized  # basic, pro, optimized 
OPENAI_REDACT=true
REDACT_SERIAL=true
SNMP_COMMUNITY=public    # public, private, cisco, public123
SNMP_VERSION=2c          # 1 | 2c | 3  (v3 is noAuthNoPriv in this minimal sample)
SNMP_TIMEOUT_MS=3000
NSA_VERBOSE=0
NSA_PING_TIMEOUT_MS=5000
PORTSCAN_BANNER_TIMEOUT_MS=1200
DNS_TIMEOUT_MS=800
DNS_SCANNER_TIMEOUT_MS=2000
DNS_QNAME=example.com
DNS_SCANNER_USE_TCP=1
SSH_BANNER_TIMEOUT=1500
CONCLUDER_SSH_TIMEOUT_AS=filtered   # filtered|closed|unknown (default: filtered)
CONCLUDER_SUMMARY_MAX_ITEMS=6
TCP_CONNECT_TIMEOUT_MS=1500
TCP_BANNER_WAIT_MS=300
TCP_MAX_BANNER_BYTES= 350
TCP_RETRIES=1
SCAN_CONCURRENCY=40
UDP_TIMEOUT_MS=850
DEBUG_MODE=0                  # verbose logging
WAPPALYZER_TIMEOUT_MS=15000   # request timeout
CONFIDENTIAL_KEYWORDS=serial,password,token
TLS_SCANNER_TIMEOUT_MS=8000
TLS_SCANNER_VERSIONS=TLSv1,TLSv1.1,TLSv1.2,TLSv1.3
TLS_SCANNER_PORTS=443:https,465:smtps,563:nntps,993:imaps,995:pop3s
TLS_SCANNER_DEBUG=0
OS_DETECTOR_HTTP_TIMEOUT_MS=5000
OS_DETECTOR_DNS_TIMEOUT_MS=2500
OS_DETECTOR_HTTP_PORTS=443,80
OS_DETECTOR_INSECURE_TLS=1
OS_DETECTOR_DEBUG=0
OS_DEBUG=0
OPENSEARCH_SCANNER_TIMEOUT_MS=6000
OPENSEARCH_SCANNER_PORTS=9200:opensearch,5601:opensearch-dashboards
OPENSEARCH_SCANNER_SCHEMES=http,https
OPENSEARCH_SCANNER_INSECURE_TLS=0
OPENSEARCH_SCANNER_DEBUG=0
OPENSEARCH_SCANNER_INCLUDE_TRANSPORT=0 
NETBIOS_TIMEOUT_MS=1200
NETBIOS_DEBUG=0
NETBIOS_DISABLE_MDNS=0
NETBIOS_DISABLE_NBNS=0
NETBIOS_DISABLE_TCP139=0
NETBIOS_DISABLE_SMB2=0
PING_DEBUG=0
ARP_DEBUG=0
MDNS_DEBUG=0
MDNS_FORCE_FALLBACK=0
MDNS_INCLUDE_NON_MATCHED=0
INSECURE_HTTPS=false
CONCLUDER_DEBUG=0
UPNP_INCLUDE_NON_MATCHED=0
UPNP_TEST_FAKE=0
AI_PROVIDER=openai                # openai | claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
