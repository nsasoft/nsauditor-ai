# NSAuditor AI — Environment Configuration
# Copy to .env and fill in your values

# ── AI Integration (optional — scans work fully offline without this) ──
AI_ENABLED=false                    # Set to true to enable AI analysis
AI_PROVIDER=openai                  # openai | claude | ollama
OPENAI_API_KEY=keychain:OPENAI_API_KEY    # or plaintext: sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=keychain:ANTHROPIC_API_KEY  # or plaintext: sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_PROMPT_MODE=optimized        # basic | pro | optimized
OPENAI_REDACT=true
CONFIDENTIAL_KEYWORDS=serial,password,token,secret

# ── Licensing (Pro/Enterprise) ──
# NSAUDITOR_LICENSE_KEY=pro_eyJhbGci...
# NSAUDITOR_PLUGIN_PATH=            # Colon-separated custom plugin dirs

# ── Output ──
SCAN_OUT_PATH=out/

# ── Plugin Timeouts ──
TLS_SCANNER_TIMEOUT_MS=8000
OPENSEARCH_SCANNER_TIMEOUT_MS=6000
DNS_TIMEOUT_MS=800
HTTP_PROBE_TIMEOUT_MS=6000
WEBAPP_DETECTOR_TIMEOUT_MS=6000
SMB_NULL_SESSION=false
ENABLE_SYN_SCAN=false
PING_FALLBACK=true

# ── Debug ──
# NSA_VERBOSE=true
# DEBUG_MODE=true
